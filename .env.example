# LLM Perturbation Experiment Configuration

# =========================================================================
# LLM Provider Selection
# =========================================================================
LLM_PROVIDER=azure_openai

# =========================================================================
# Azure OpenAI Configuration
# =========================================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-api-key
AZURE_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=gpt-5.2

# =========================================================================
# Anthropic Claude Configuration
# =========================================================================
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-3-opus-20250219

# =========================================================================
# Google Gemini Configuration
# =========================================================================
GOOGLE_API_KEY=AIzaSy...
GOOGLE_MODEL=gemini-2.0-flash

# =========================================================================
# Experiment Settings
# =========================================================================
NUM_PERTURBATIONS=2
MAX_RETRIES=3
RETRY_DELAY=1.0
LLM_TEMPERATURE=0.0

# =========================================================================
# Retrieval Perturbations
# =========================================================================
# Set to true to enable retrieval-augmented perturbations
USE_RETRIEVAL=false
# Path to the context/training dataset used for nearest-neighbour retrieval
CONTEXT_DATA_PATH=data/context_ready.csv


